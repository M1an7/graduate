# =========================================================
# External interfaces (to implement in your codebase)
# =========================================================

class SecureSumCollector:
    """External: must return ONLY the sum, hiding per-client vectors from the server."""
    def sum_vectors(self, vectors: List[torch.Tensor]) -> torch.Tensor:
        raise NotImplementedError

class MaskedSecureSum(SecureSumCollector):
    """基于加法掩码的安全聚合模拟实现"""
    def __init__(self, num_clients: int, dim: int, device='cpu'):
        self.num_clients = num_clients
        # 实际场景中，掩码需要在客户端生成并在服务器端配对抵消
        # 这里假设输入 vectors 已经是带掩码的，且掩码之和为0
    
    def sum_vectors(self, vectors: List[torch.Tensor]) -> torch.Tensor:
        if len(vectors) == 0:
            return torch.tensor([])
        
        # 核心逻辑：直接相加。
        # 在真正的 SecAgg 协议中，客户端上传的是 (data + mask_i)。
        # 服务器执行 sum(data + mask_i) = sum(data) + sum(mask_i)。
        # 如果协议正确，sum(mask_i) 应该等于 0，从而还原 sum(data)。
        result = vectors[0].clone()
        for v in vectors[1:]:
            result += v
            
        return result

class ReconstructSolver:
    """External: solve A_tr * x = y_tr (possibly underdetermined) to produce x_hat (int64)."""
    def solve(self, Aop: "MeasurementOperator", y: torch.Tensor) -> torch.Tensor:
        raise NotImplementedError

from typing import Tuple, List

    
import torch

class RidgeMinNormCGSolver(ReconstructSolver):
    """
    Solve x = A^T (A A^T + lam I)^{-1} y
    via Conjugate Gradient on u: (A A^T + lam I) u = y, then x = A^T u.

    Params:
      lam: ridge regularization (stability)
      cg_iters: CG iterations
      cg_tol: stopping tolerance
    """
    def __init__(self, lam=1e-2, cg_iters=50, cg_tol=1e-6):
        self.lam = float(lam)
        self.cg_iters = int(cg_iters)
        self.cg_tol = float(cg_tol)



    def solve(self, Aop, y):
        """
        使用共轭梯度法 (CG) 求解 (A A^T + lam*I) u = y, 然后计算 x = A^T u.
        带进度条显示。
        """
        # Aop must provide:
        #   forward_float(x):  y = A x  (float version)
        #   transpose(u):      x = A^T u
        
        y = y.to(torch.float32)
        m = y.numel()
        
        # 预计算 y 的范数用于相对收敛判断
        y_norm_sq = torch.dot(y, y).item()
        if y_norm_sq == 0:
            return torch.zeros(Aop.d, dtype=torch.int64)

        def M(u):
            # 注意：这里假设 Aop 有 forward_float 方法处理 float 输入
            # 如果只有 forward (int)，可能需要临时转换或修改 Aop
            Au = Aop.transpose(u)          # float32 [d]
            AATu = Aop.forward_float(Au)   # float32 [m]
            return AATu + self.lam * u

        # 初始化 CG
        u = torch.zeros(m, dtype=torch.float32, device=y.device)
        r = y - M(u)
        p = r.clone()
        rsold = torch.dot(r, r)
        
        initial_res_norm = torch.sqrt(rsold).item()

        # <--- 2. 使用 tqdm 包装循环
        with tqdm(range(self.cg_iters), desc="CG Solving", unit="iter", leave=False) as t:
            for i in t:
                Ap = M(p)
                pAp = torch.dot(p, Ap)
                
                # 防止除以零
                if pAp.item() == 0:
                    break
                    
                alpha = rsold / (pAp + 1e-12)
                u = u + alpha * p
                r = r - alpha * Ap
                
                rsnew = torch.dot(r, r)
                res_norm = torch.sqrt(rsnew).item()
                
                # 收敛判断
                # 相对残差平方 < tol^2
                if rsnew.item() < (self.cg_tol**2) * (y_norm_sq + 1e-12):
                    t.set_description(f"CG Converged (res={res_norm:.2e})")
                    t.close()
                    break
                
                # 更新搜索方向
                p = r + (rsnew / (rsold + 1e-12)) * p
                rsold = rsnew
                
                # <--- 3. 更新进度条显示的信息
                # 显示当前迭代数和残差范数
                t.set_description(f"CG Iter (res={res_norm:.2e})")

        # 恢复解 x = A^T u
        x_hat = Aop.transpose(u)
        
        # 四舍五入并转为 int64
        x_int = torch.round(x_hat).to(torch.int64)
        
        return x_int


class ModelAdapter:
    """External: adapt your model object to/from a flat parameter vector."""
    def get_vector(self, model: Any) -> torch.Tensor:
        raise NotImplementedError

    def get_vector_from_tensor(self, tensor: torch.Tensor) -> torch.Tensor:
        """Get vector from tensor (for quantized values)"""
        return tensor.flatten()

    def set_vector(self, model: Any, vec: torch.Tensor) -> None:
        raise NotImplementedError

    def apply_update(self, model: Any, delta: torch.Tensor, lr: float) -> None:
        """In-place update: w <- w + lr * delta"""
        raise NotImplementedError


class PyTorchModelAdapter(ModelAdapter):
    """
    具体的 PyTorch 模型适配器。
    它将模型的所有参数展平为一个向量，并能将向量还原回模型。
    """
    def __init__(self, param_shapes: List[torch.Size], param_dtypes: List[torch.dtype], device: torch.device):
        """
        初始化时需要知道模型参数的结构，以便正确还原。
        通常在创建时通过观察一个空模型或示例模型来获取这些信息。
        """
        self.param_shapes = param_shapes
        self.param_dtypes = param_dtypes
        self.device = device
        self.total_dim = sum(s.numel() for s in param_shapes)

    def get_vector(self, model: Any) -> torch.Tensor:
        """将模型参数展平为一个大向量"""
        params = []
        for p in model.parameters():
            if p.requires_grad:
                params.append(p.data.detach().flatten())
        if not params:
            return torch.zeros(0, device=self.device)
        return torch.cat(params).to(self.device)

    def set_vector(self, model: Any, vec: torch.Tensor) -> None:
        """将大向量切分并还原到模型参数中"""
        current_idx = 0
        # 获取需要更新的参数列表 (只更新 requires_grad 的)
        trainable_params = [p for p in model.parameters() if p.requires_grad]
        
        if len(trainable_params) != len(self.param_shapes):
            raise ValueError(f"参数数量不匹配！模型有 {len(trainable_params)} 个可训练参数，但适配器期望 {len(self.param_shapes)} 个。")

        for i, p in enumerate(trainable_params):
            shape = self.param_shapes[i]
            numel = shape.numel()
            
            # 切片
            param_vec = vec[current_idx : current_idx + numel]
            
            # 重塑并赋值
            with torch.no_grad():
                p.data.copy_(param_vec.reshape(shape).to(p.dtype).to(p.device))
            
            current_idx += numel
        
        if current_idx != vec.numel():
            raise ValueError(f"向量长度不匹配！使用了 {current_idx}，但向量总长 {vec.numel()}")

    def apply_update(self, model: Any, delta: torch.Tensor, lr: float) -> None:
        """
        原地更新模型：w <- w + lr * delta
        这比 set_vector 更高效，因为它不需要重新分配内存，直接操作数据。
        """
        current_idx = 0
        trainable_params = [p for p in model.parameters() if p.requires_grad]
        
        if len(trainable_params) != len(self.param_shapes):
             raise ValueError("参数数量不匹配，无法应用更新。")

        with torch.no_grad():
            for i, p in enumerate(trainable_params):
                shape = self.param_shapes[i]
                numel = shape.numel()
                
                # 提取对应的 delta 片段
                delta_slice = delta[current_idx : current_idx + numel].reshape(shape)
                
                # 执行更新: p = p + lr * delta
                # 注意：delta 可能是 float32，p 可能是 float16 或 float32，需对齐 dtype
                p.data.add_(delta_slice.to(p.device).to(p.dtype), alpha=lr)
                
                current_idx += numel

# =========================================================
# CARA configuration (parameters)
# =========================================================

@dataclass
class CARAConfig:
    # paper knobs
    b: int = 16               # quantization bits (8/16/32)
    m_tr: int = 32768         # training measurements
    m_au: int = 64            # audit measurements
    s: int = 2                # minimum cohort size
    tau: int = 200000              # audit tolerance in int domain
    rho: float = 1.0          # audit frequency

    # operator construction / efficiency
    k_row: int = 64           # sparsity per measurement row (<= d), higher => better fidelity but more compute
    quant_scale: Optional[float] = None  # if set, overrides b-based scale selection

    # deterministic RNG
    seed: int = 0

    # optional: commit-then-reveal (not fully implemented; placeholder)
    use_commit_reveal: bool = False


# =========================================================
# Main CARA class
# =========================================================

class CARA:
    """
    Co-Audited Randomized Aggregation (CARA) main class.
    """
    def __init__(self, cfg: CARAConfig, secsum: SecureSumCollector, solver: ReconstructSolver):
        self.cfg = cfg
        self.secsum = secsum
        self.solver = solver
        self.model_adapter = ModelAdapter()

    def round_policy(self, round_idx: int, participants: Sequence[int]) -> Dict[str, Any]:
        """Decide whether to run round, audit, etc."""
        n = len(participants)
        audit = (round_idx % int(1.0 / self.cfg.rho)) == 0 if self.cfg.rho > 0 else False
        allow_round = n >= self.cfg.s
        return {
            "allow_round": allow_round,
            "audit": audit,
            "n": n,
            "participants": list(participants),
        }

    def make_seed_t(self, round_idx: int) -> int:
        """Deterministic seed for this round."""
        return _hash_to_u64(f"round={round_idx}|seed={self.cfg.seed}")

    def client_make_measurements(
        self,
        *,
        round_idx: int,
        seed_t: int,
        model: Any,
        client_update_fn: Callable[[Any], torch.Tensor],
        audit: bool,
    ) -> Dict[str, Any]:
        """
        Client: compute local update, quantize, measure.
        Returns measurements to send to server.
        """
        # Get local update delta (float tensor)
        delta_float = client_update_fn(model)

        # Quantize to int
        delta_int, delta_scale = quantize(delta_float, self.cfg.b, self.cfg.quant_scale)

        # Flatten to vector
        delta_vec = self.model_adapter.get_vector_from_tensor(delta_int)

        d = delta_vec.numel()

        # Training measurements
        A_tr = MeasurementOperator(seed_t=seed_t, tag="tr", m=self.cfg.m_tr, d=d, k_row=self.cfg.k_row)
        y_tr = A_tr.forward(delta_vec)

        out = {
            "y_tr": y_tr,
            "delta_scale": delta_scale,
            "d": d,
        }

        if audit:
            # Audit measurements
            A_au = MeasurementOperator(seed_t=seed_t, tag="au", m=self.cfg.m_au, d=d, k_row=self.cfg.k_row)
            y_au = A_au.forward(delta_vec)
            out["y_au"] = y_au
        else:
            out["y_au"] = None

        return out

    def secure_sum_measurements(
        self,
        *,
        batch: List[Dict[str, Any]],
        audit: bool,
    ) -> Dict[str, Any]:
        # y_tr sum
        y_tr_list = [m["y_tr"] for m in batch]

        y_tr_sum = self.secsum.sum_vectors(y_tr_list).to(torch.int64)

        out = {"y_tr_sum": y_tr_sum}

        if audit:
            y_au_list = [m["y_au"] for m in batch]
            assert all(v is not None for v in y_au_list), "missing y_au in audited round"
            y_au_sum = self.secsum.sum_vectors([v for v in y_au_list if v is not None]).to(torch.int64)
            out["y_au_sum"] = y_au_sum
        else:
            out["y_au_sum"] = None

        # For simplicity assume shared scale; in practice use a fixed scale across clients.
        out["scale"] = float(batch[0]["delta_scale"])
        out["d"] = int(batch[0]["d"])
        return out

    def server_reconstruct_proposal(
        self,
        *,
        seed_t: int,
        d: int,
        y_tr_sum: torch.Tensor,
    ) -> torch.Tensor:
        A_tr = MeasurementOperator(seed_t=seed_t, tag="tr", m=self.cfg.m_tr, d=d, k_row=self.cfg.k_row)
        # External solver returns int64 vector [d]
        delta_hat_int = self.solver.solve(A_tr, y_tr_sum).to(torch.int64)
        return delta_hat_int

    def client_verify_and_apply(
        self,
        *,
        seed_t: int,
        model: Any,
        delta_hat_int: torch.Tensor,
        y_au_sum: Optional[torch.Tensor],
        audit: bool,
        scale: float,
        n: int,
        lr: float,
    ) -> bool:
        """
        Returns True if applied, False if rejected.
        """
        if audit:
            assert y_au_sum is not None
            d = delta_hat_int.numel()
            A_au = MeasurementOperator(seed_t=seed_t, tag="au", m=self.cfg.m_au, d=d, k_row=self.cfg.k_row)
            y_hat_au = A_au.forward(delta_hat_int)
            # infinity norm check
            diff = (y_hat_au - y_au_sum.to(torch.int64)).abs()
            print(f"Audit check: ||y_hat_au - y_au_sum||_inf = {diff.max().item()}, tau={self.cfg.tau}")
            if int(diff.max().item()) > int(self.cfg.tau):
                # reject: keep local model unchanged
                return False

        # apply-if-verified: each client updates locally
        delta_hat = dequantize(delta_hat_int, scale) / max(1, int(n))
        self.model_adapter.apply_update(model, delta_hat, lr)
        return True

    def aggregate_updates(self, client_updates: List[Dict[str, torch.Tensor]], global_model: Any) -> Dict[str, torch.Tensor]:
        """
        Simplified aggregation method for replacing FedAvg in main_recon.py
        For now, just return FedAvg result. In full CARA implementation, this would use
        the secure aggregation protocol with measurements and reconstruction.
        """
        if len(client_updates) == 0:
            return {}

        # For compatibility with main_recon.py, use FedAvg for now
        # In a full CARA implementation, this would involve:
        # 1. Client measurements
        # 2. Secure aggregation
        # 3. Server reconstruction
        # 4. Client verification and application

        # Simple FedAvg implementation
        param_keys = list(client_updates[0].keys())
        aggregated_update = {}

        for key in param_keys:
            updates = [update[key] for update in client_updates if key in update]
            if updates:
                aggregated_update[key] = torch.stack(updates).mean(dim=0)

        return aggregated_update


# =========================================================
# Step helpers: deterministic seeds, quantization, sparse measurement operator
# =========================================================

def _hash_to_u32(s: str) -> int:
    h = hashlib.sha256(s.encode()).digest()
    return int.from_bytes(h[:4], "little", signed=False)

def _hash_to_u64(s: str) -> int:
    h = hashlib.sha256(s.encode()).digest()
    return int.from_bytes(h[:8], "little", signed=False)

def choose_quant_scale(delta_float: torch.Tensor, b: int) -> float:
    """Simple symmetric scale so values fit in signed b-bit."""
    max_int = (2 ** (b - 1)) - 1
    max_abs = float(delta_float.abs().max().item()) + 1e-12
    return max_abs / max_int

def quantize(delta_float: torch.Tensor, b: int, quant_scale: Optional[float]) -> Tuple[torch.Tensor, float]:
    scale = quant_scale if quant_scale is not None else choose_quant_scale(delta_float, b)
    delta_int = torch.round(delta_float / scale).to(torch.int64)
    return delta_int, float(scale)

def dequantize(delta_int: torch.Tensor, scale: float) -> torch.Tensor:
    return delta_int.to(torch.float32) * float(scale)


class MeasurementOperator:
    """
    Implicit measurement operator A in {-1,+1}^{m x d} (sparse Rademacher rows),
    generated deterministically from (seed_t, tag, row_index).

    We support:
      - forward(x): y = A x, where x is int64 vector of shape [d], y is int64 [m]
      - apply_to_candidate(x): same as forward (used for audit)
    """
    def __init__(self, *, seed_t: int, tag: str, m: int, d: int, k_row: int):
        self.seed_t = int(seed_t)
        self.tag = str(tag)
        self.m = int(m)
        self.d = int(d)
        self.k_row = int(min(k_row, d))

    def _row_rng(self, row: int) -> random.Random:
        key = f"{self.seed_t}|{self.tag}|row={row}"
        return random.Random(_hash_to_u64(key))

    def _row_indices_and_signs(self, row: int) -> Tuple[List[int], List[int]]:
        """
        Produce k_row indices and +/-1 signs for this row.
        Deterministic from (seed_t, tag, row).
        """
        rr = self._row_rng(row)
        # sample k distinct indices
        idx = rr.sample(range(self.d), self.k_row)
        # signs
        sgn = [1 if rr.getrandbits(1) else -1 for _ in range(self.k_row)]
        return idx, sgn
    
    def transpose(self, u: torch.Tensor) -> torch.Tensor:
        """
        Compute x = A^T u, where:
        - u is length-m vector (float32 or int64)
        - returns length-d vector (float32) accumulating sparse rows

        For each row r:
        indices idx[r], signs sgn[r]
        y_r = u[r]
        then x[idx[j]] += sgn[j] * y_r

        Complexity: O(m * k_row)
        """
        assert u.ndim == 1 and u.numel() == self.m, f"u must be shape [{self.m}]"
        # We'll accumulate in float32 for CG stability
        u_f = u.to(torch.float32)

        x = torch.zeros(self.d, dtype=torch.float32)

        for r in range(self.m):
            idx, sgn = self._row_indices_and_signs(r)
            ur = float(u_f[r].item())
            # add contributions back to coordinates
            for j, sj in zip(idx, sgn):
                x[j] += float(sj) * ur

        return x

    def forward(self, x_int: torch.Tensor) -> torch.Tensor:
        assert x_int.dtype == torch.int64 and x_int.ndim == 1 and x_int.numel() == self.d
        y = torch.zeros(self.m, dtype=torch.int64)
        # Each row: dot(sparse +/-1, x)
        for r in range(self.m):
            idx, sgn = self._row_indices_and_signs(r)
            # manual dot
            acc = 0
            for j, sj in zip(idx, sgn):
                acc += sj * int(x_int[j].item())
            y[r] = acc
        return y

    def forward_float(self, x: torch.Tensor) -> torch.Tensor:
        """
        Compute y = A x for float32 x (shape [d]), returning float32 y (shape [m]).
        Uses the same sparse rows as forward().
        """
        assert x.ndim == 1 and x.numel() == self.d
        x_f = x.to(torch.float32)
        y = torch.zeros(self.m, dtype=torch.float32)
        for r in range(self.m):
            idx, sgn = self._row_indices_and_signs(r)
            acc = 0.0
            for j, sj in zip(idx, sgn):
                acc += float(sj) * float(x_f[j].item())
            y[r] = acc
        return y

# =========================================================
# CARA main protocol (steps labeled)
# =========================================================

class CARAProtocol:
    def __init__(
        self,
        cfg: CARAConfig,
        *,
        model_adapter: ModelAdapter,
        secsum: SecureSumCollector,
        solver: ReconstructSolver,
    ):
        self.cfg = cfg
        self.model_adapter = model_adapter
        self.secsum = secsum
        self.solver = solver
        self.rng = random.Random(cfg.seed)

    # ---------- Step 0: round policy ----------
    def round_policy(self, round_idx: int, participants: Sequence[int]) -> Dict[str, Any]:
        n = len(participants)
        allow = n >= int(self.cfg.s)

        # audit coin flip (deterministic)
        audit = False
        if allow and self.cfg.m_au > 0 and self.cfg.rho > 0:
            u = _hash_to_u32(f"{self.cfg.seed}|audit|{round_idx}") / 2**32
            audit = (u < float(self.cfg.rho))

        return {"allow_round": allow, "audit": audit, "n": n}

    # Generate a public seed_t (optionally commit-then-reveal at system level)
    def make_seed_t(self, round_idx: int) -> int:
        return _hash_to_u32(f"{self.cfg.seed}|seed_t|{round_idx}")

    # ---------- Step 1-3: client local update -> quantize -> measure ----------
    def client_make_measurements(
        self,
        *,
        round_idx: int,
        seed_t: int,
        model: Any,
        client_update_fn: Callable[[Any, int], torch.Tensor],
        audit: bool,
    ) -> Dict[str, Any]:
        """
        client_update_fn(model, round_idx) -> delta_float_flat (torch.float32 [d])
        """
        # Step 1: local update
        # delta_float = client_update_fn(model, round_idx).detach().clone().to(torch.float32)
        print("Client computing local update...round_idx =", round_idx )
        delta_float,_= client_update_fn(model) # Assuming it returns a state_dict of tensors
        # input(f"Debug: delta_float = {delta_float}. Press Enter to continue...")

        delta_float = torch.cat([v.flatten() for v in delta_float.values()])
        d = delta_float.numel()

        # Step 2: quantize
        delta_int, used_scale = quantize(delta_float, self.cfg.b, self.cfg.quant_scale)

        # Step 3: measurement operators (implicit)
        A_tr = MeasurementOperator(seed_t=seed_t, tag="tr", m=self.cfg.m_tr, d=d, k_row=self.cfg.k_row)

        y_tr = A_tr.forward(delta_int)
        y_au = None
        if audit:
            A_au = MeasurementOperator(seed_t=seed_t, tag="au", m=self.cfg.m_au, d=d, k_row=self.cfg.k_row)
            y_au = A_au.forward(delta_int)

        return {
            "delta_scale": used_scale,  # for dequantize later (ideally fixed globally)
            "y_tr": y_tr,               # int64 [m_tr]
            "y_au": y_au,               # int64 [m_au] or None
            "d": d,
        }

    # ---------- Step 4: secure sum of measurements ----------
    def secure_sum_measurements(
        self,
        *,
        batch: List[Dict[str, Any]],
        audit: bool,
    ) -> Dict[str, Any]:
        # y_tr sum
        y_tr_list = [m["y_tr"] for m in batch]

        y_tr_sum = self.secsum.sum_vectors(y_tr_list).to(torch.int64)

        out = {"y_tr_sum": y_tr_sum}

        if audit:
            y_au_list = [m["y_au"] for m in batch]
            assert all(v is not None for v in y_au_list), "missing y_au in audited round"
            y_au_sum = self.secsum.sum_vectors([v for v in y_au_list if v is not None]).to(torch.int64)
            out["y_au_sum"] = y_au_sum
        else:
            out["y_au_sum"] = None

        # For simplicity assume shared scale; in practice use a fixed scale across clients.
        out["scale"] = float(batch[0]["delta_scale"])
        out["d"] = int(batch[0]["d"])
        return out

    # ---------- Step 5: server reconstruct aggregated update (proposal) ----------
    def server_reconstruct_proposal(
        self,
        *,
        seed_t: int,
        d: int,
        y_tr_sum: torch.Tensor,
    ) -> torch.Tensor:
        A_tr = MeasurementOperator(seed_t=seed_t, tag="tr", m=self.cfg.m_tr, d=d, k_row=self.cfg.k_row)
        # External solver returns int64 vector [d]
        delta_hat_int = self.solver.solve(A_tr, y_tr_sum).to(torch.int64)
        return delta_hat_int

    # ---------- Step 7-8: client audit + apply-if-verified ----------
    def client_verify_and_apply(
        self,
        *,
        seed_t: int,
        model: Any,
        delta_hat_int: torch.Tensor,
        y_au_sum: Optional[torch.Tensor],
        audit: bool,
        scale: float,
        n: int,
        lr: float,
    ) -> bool:
        """
        Returns True if applied, False if rejected.
        """
        if audit:
            assert y_au_sum is not None
            d = delta_hat_int.numel()
            A_au = MeasurementOperator(seed_t=seed_t, tag="au", m=self.cfg.m_au, d=d, k_row=self.cfg.k_row)
            y_hat_au = A_au.forward(delta_hat_int)
            # infinity norm check
            diff = (y_hat_au - y_au_sum.to(torch.int64)).abs()
            print(f"Audit check: ||y_hat_au - y_au_sum||_inf = {diff.max().item()}, tau={self.cfg.tau}")
            if int(diff.max().item()) > int(self.cfg.tau):
                # reject: keep local model unchanged
                return False

        # apply-if-verified: each client updates locally
        delta_hat = dequantize(delta_hat_int, scale) / max(1, int(n))
        self.model_adapter.apply_update(model, delta_hat, lr)
        net_glob = model
        return net_glob

    # =========================================================
    # One full round driver (for clarity)
    # =========================================================
    def run_round(
        self,
        *,
        round_idx: int,
        participant_ids: Sequence[int],
        client_models: Dict[int, Any],
        # client_update_fn can be a single callable or a dict mapping cid->callable
        client_update_fn: Union[Callable[[Any], torch.Tensor], Dict[int, Callable[[Any], torch.Tensor]]],
        lr: float,
    ) -> Dict[str, Any]:
        """
        This is a reference "driver" for one round.
        Your real system may separate client/server processes; this shows the step flow.

        Returns logs useful for experiments:
          - applied_frac, audit, comm estimates, etc.
        """
        # Step 0
        print(f"=== Round {round_idx} ===")
        print("Step 0: round policy and seed generation...")
        pol = self.round_policy(round_idx, participant_ids)
        if not pol["allow_round"]:
            return {"round": round_idx, "skipped": 1, "reason": "cohort_too_small", **pol}

        audit = bool(pol["audit"])
        n = int(pol["n"])
        seed_t = self.make_seed_t(round_idx)

        # Step 1-3 per client
        print(f"Step 1-3: clients make measurements (audit={audit})...")
        msgs = []
        for cid in participant_ids:
            # support either a single callable or a mapping from cid->callable
            if isinstance(client_update_fn, dict):
                fn = client_update_fn[cid]
            else:
                fn = client_update_fn

            msg = self.client_make_measurements(
                round_idx=round_idx,
                seed_t=seed_t,
                model=client_models[cid],
                client_update_fn=fn,
                audit=audit,
            )
            msgs.append(msg)

        # Step 4 secure sum
        print("Step 4: server securely aggregates measurements...")
        agg = self.secure_sum_measurements(batch=msgs, audit=audit)

        # Step 5 server reconstruct proposal
        print("Step 5: server reconstructs proposal...")
        delta_hat_int = self.server_reconstruct_proposal(seed_t=seed_t, d=agg["d"], y_tr_sum=agg["y_tr_sum"])

        # Step 7-8 clients verify + apply
        print("Step 7-8: clients verify proposal and apply if valid...")
        applied = 0
        for cid in participant_ids:
            ok = self.client_verify_and_apply(
                seed_t=seed_t,
                model=client_models[cid],
                delta_hat_int=delta_hat_int,
                y_au_sum=agg["y_au_sum"],
                audit=audit,
                scale=agg["scale"],
                n=n,
                lr=lr,
            )
            applied += int(bool(ok))

        applied_frac = applied / max(1, n)

        # Communication accounting (bits/param/client), reporting-only:
        # each client sends y_tr (m_tr int64) and maybe y_au (m_au int64)
        # plus negligible headers. Divide by d to get bits/param.
        d = int(agg["d"])
        scalar_bits = 64
        bits_per_client = scalar_bits * (self.cfg.m_tr + (self.cfg.m_au if audit else 0))
        bits_per_param = bits_per_client / max(1, d)

        return {
            "round": round_idx,
            "skipped": 0,
            "audit": int(audit),
            "applied_frac": applied_frac,
            "bits_per_param_client": bits_per_param,
            "m_tr": self.cfg.m_tr,
            "m_au": (self.cfg.m_au if audit else 0),
            "tau": int(self.cfg.tau),
            "n": n,
        }


# =========================================================
# Notes for you (implementation guidance)
# =========================================================
"""
How to plug in quickly:

1) Implement SecureSumCollector:
   - For simulation, you can start with a trusted sum:
       return torch.stack(vectors).sum(0)
   - For your real defense comparison, replace with SA/shuffler so server never sees per-client y_i.

2) Implement ReconstructSolver:
   - Start with a simple baseline that returns zeros (won't train, but tests audit plumbing).
   - Better: min-norm solution using iterative methods on implicit A:
       minimize ||x||_2 subject to A x = y
     (or least squares: minimize ||A x - y||_2^2 + lambda||x||_2^2)

   - In practice, you may prefer block-wise reconstruction to reduce compute.

3) Implement ModelAdapter:
   - get_vector / set_vector / apply_update for your model.

4) Implement client_update_fn:
   - Should compute delta between local-trained model and starting model.
   - In this scaffold we assume it returns a flat vector of length d.

Security note:
- The audit checks integrity of the *proposed* delta_hat_int with respect to aggregated audit measurements.
- If the server deviates by adding injection g, it must satisfy A_au g = 0 to avoid detection; probability decreases with m_au.

Experiment knobs:
- SA-side: m_tr (main), b, s
- AUD-side: m_au, tau, rho
"""

def updatess(model,round_index):
    derta = model.state_dict()
    return torch.cat([v.flatten() for v in derta.values()])

def main():

    PERCN_OF_SHADOW = 0.05
    top_k = 1
    args = args_parser()
    args.device = torch.device('cuda:{}'.format(args.gpu) if torch.cuda.is_available() and args.gpu != -1 else 'cpu')
    net_glob = Mnistcnn(args=args).to(args.device)
    dataset_train, dataset_test, dict_party_user, dict_sample_user = get_dataset(args)
    acc_train, loss_train_ = test_fun_topk(net_glob, dataset_train, args,top_k=top_k)
    acc_test, loss_test = test_fun_topk(net_glob, dataset_test, args,top_k=top_k)
    print("[Vanilla FL] Training accuracy of the joint model: {:.2f}%".format(acc_train))
    print("[Vanilla FL] Testing accuracy of the joint model: {:.2f}%".format(acc_test))

    param_shapes = [p.shape for p in net_glob.parameters() if p.requires_grad]
    param_dtypes = [p.dtype for p in net_glob.parameters() if p.requires_grad]

    example = CARAProtocol(cfg=CARAConfig(), model_adapter=PyTorchModelAdapter(param_shapes=param_shapes, param_dtypes=param_dtypes, device=torch.device("cpu")), secsum=MaskedSecureSum(num_clients=3, dim=100), solver=RidgeMinNormCGSolver())
    # build a mapping from client id -> their LocalUpdate.train callable
    client_ids = list(range(min(args.num_users, 10)))

    # instantiate client models once and move to device
    client_models = {cid: Mnistcnn(args=args).to(args.device) for cid in client_ids}

    # build a mapping from client id -> their LocalUpdate.train callable
    client_update_map = {
        cid: LocalUpdate(args=args, dataset=dataset_train, idxs=dict_party_user[cid], shadow=False, PERCN_OF_SHADOW=PERCN_OF_SHADOW).train
        for cid in client_ids
    }

    # compute per-client weights from local dataset sizes
    size_per_client = [len(dict_party_user[cid]) for cid in client_ids]
    total_size = sum(size_per_client)
    if total_size > 0:
        size_weight = np.array(size_per_client) / total_size
    else:
        size_weight = np.ones(len(client_ids)) / len(client_ids)

    # run multiple communication rounds as configured
    for round_idx in range(args.epochs):
        print(f"\n--- Communication Round {round_idx} / {args.epochs - 1} ---")
        round_info = example.run_round(
            round_idx=round_idx,
            participant_ids=client_ids,
            client_models=client_models,
            client_update_fn=client_update_map,
            lr=args.lr,
        )

        # aggregate client models (Vanilla FL aggregation) and evaluate
        client_state_dicts = [client_models[cid].state_dict() for cid in client_ids]
        w_glob_after = FedAvg(client_state_dicts, size_weight)
        net_glob.load_state_dict(w_glob_after)
        net_glob.eval()
        # 统一准确率评估逻辑
        acc_train_after, _ = test_fun_topk(net_glob, dataset_train, args, top_k=top_k)
        acc_test_after, _ = test_fun_topk(net_glob, dataset_test, args, top_k=top_k)
        print("[Vanilla FL] Training accuracy of the joint model after round {}: {:.2f}%".format(round_idx, acc_train_after))
        print("[Vanilla FL] Testing accuracy of the joint model after round {}: {:.2f}%".format(round_idx, acc_test_after))

        # --- Evaluate SIA/ESIA attack success on the current set of client models ---
        try:
            from models.Sia import SIA, ESIA
            w_locals_map = {cid: client_state_dicts[i] for i, cid in enumerate(client_ids)}
            dict_mia_subset = {cid: dict_sample_user[cid] for cid in client_ids if cid in dict_sample_user}
            empty_net = Mnistcnn(args=args).to(args.device)
            sia = SIA(args=args, w_locals=w_locals_map, dataset=dataset_train, dict_mia_users=dict_mia_subset)
            sia_acc = sia.attack(net=empty_net)
            print(f"[SIA Attack] Success rate after round {round_idx}: {sia_acc:.2f}%")
            esia = ESIA(args=args, w_locals=w_locals_map, dataset=dataset_train, dict_mia_users=dict_mia_subset)
            esia_acc = esia.attack(net=empty_net)
            print(f"[ESIA Attack] Success rate after round {round_idx}: {esia_acc:.2f}%")
        except Exception as e:
            print(f"[SIA/ESIA Attack] evaluation skipped due to error: {e}")

        # --- 记录通信开销（KB） ---
        sia_comm_kb = esia_comm_kb = 0.0
        try:
            bits_per_param_client = float(round_info.get('bits_per_param_client', 0.0))
            d = sum(p.numel() for p in net_glob.parameters() if p.requires_grad)
            n = int(round_info.get('n', len(client_ids)))
            total_bits_round = bits_per_param_client * d * n
            sia_comm_kb = total_bits_round / 1024.0
            esia_comm_kb = sia_comm_kb  # 若有不同通信逻辑可分别计算
        except Exception:
            pass

        # --- 写入 logs.csv ---
        import csv
        with open('logs.csv', 'a') as f:
            writer = csv.writer(f)
            writer.writerow([
                round_idx,
                f"{sia_acc:.2f}",
                f"{esia_acc:.2f}",
                f"{acc_train_after:.2f}",
                f"{acc_test_after:.2f}",
                f"{sia_comm_kb:.2f}",
                f"{esia_comm_kb:.2f}"
            ])

        # --- Communication overhead (KB) ---
        try:
            bits_per_param_client = float(round_info.get('bits_per_param_client', 0.0))
            # compute d = total number of trainable parameters
            d = sum(p.numel() for p in net_glob.parameters() if p.requires_grad)
            n = int(round_info.get('n', len(client_ids)))
            total_bits_round = bits_per_param_client * d * n
            total_kb_round = total_bits_round / 1024.0
            print(f"[Comm] bits_per_param_client={bits_per_param_client:.2f}, d={d}, n={n}, total_communication={total_kb_round:.2f} KB")
        except Exception as e:
            print(f"[Comm] communication accounting skipped due to error: {e}")

   
